# Step 1 generic API settings (template values only; do not commit real secrets)
API_BASE_URL=https://api.example.com/v1
API_KEY=your_api_key_here
MODEL_NAME=deepseek-chat
MYSQL_PASSWORD=your_mysql_password_here

# 运行环境；真实密钥请分别放入 .env.dev/.env.test/.env.prod
APP_ENV=dev

# Compatibility settings used by the existing chatbot implementation
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
DEFAULT_MODEL=deepseek-chat
DATABASE_URL=sqlite:///data/chatbot.db
CHAT_TEMPERATURE=0.7
MAX_HISTORY_MESSAGES=30

# Optional provider-specific settings for OpenAI-compatible APIs
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
QWEN_API_KEY=your_api_key_here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
